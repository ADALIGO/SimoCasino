{
  "name": "simocasino",
  "version": "1.0.0",
  "description": "A comprehensive Next.js fullstack casino platform with Turbopack, Prisma, and MongoDB",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbopack": "next dev --turbopack",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:build": "node prisma/build-schema.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:dbpush": "npm run prisma:build && prisma db push",
    "dbpush-fast": "npm run prisma:build && prisma db push",
    "auto-dbpush": "npm run prisma:build && prisma db push",
    "prisma:deploy": "npm run prisma:build && prisma db push && prisma generate",
    "prisma:seed": "node --loader ts-node/esm prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "seed:fast": "node seed-fast.mjs",
    "split-casino-json": "node split-casino-json.mjs",
    "clear-casinos": "node clear-casinos.mjs",
    "import-folder-casinos": "node import-folder-casinos.mjs",
    "import-casinos": "node import_casinos.js",
    "preprisma:migrate": "node prisma/build-schema.mjs",
    "preprisma:generate": "node prisma/build-schema.mjs",
    "preprisma:seed": "node prisma/build-schema.mjs",
    "optimize": "npm run lint:fix && npm run type-check && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@reduxjs/toolkit": "^1.9.7",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/analytics": "^1.6.1",
    "aos": "^2.3.4",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "framer-motion": "^10.16.19",
    "i18next": "^22.5.1",
    "lucide-react": "^1.6.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^12.3.1",
    "react-redux": "^8.1.3",
    "react-toastify": "^9.1.3",
    "sass": "^1.69.5"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.32",
    "prisma": "^5.7.1",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "next.js",
    "casino",
    "prisma",
    "mongodb",
    "redux",
    "fullstack"
  ],
  "author": "",
  "license": "ISC"
}
