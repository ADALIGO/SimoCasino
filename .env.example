# Example environment variables for local development and Vercel deployment
# Copy this file to .env.local and fill in your real credentials.

DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/simocasino?retryWrites=true&w=majority"

# Cloudinary (server-side upload API)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cloudinary client-side widget
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Optional runtime API base URL when needed
NEXT_PUBLIC_API_URL="https://your-app.vercel.app"
